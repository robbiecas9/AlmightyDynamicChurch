{
    "compilerOptions": {
      "target": "ESNext",
      "module": "ESNext",
      "moduleResolution": "Node",
      "baseUrl": ".",
      "paths": {
        "@shared/*": ["../shared/*"]
      },
      "esModuleInterop": true,
      "strict": true,
      "skipLibCheck": true
    },
    "include": ["./**/*.ts"]
  }
  